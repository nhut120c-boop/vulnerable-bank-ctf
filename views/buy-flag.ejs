<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Kho Bạc VIP | Vulnerable Bank</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="vb-topbar">
    <a href="/dashboard" class="vb-logo">
      <svg class="mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="#12315C"/>
        <path d="M16 6L27 11V13H5V11L16 6Z" fill="#E7D28C"/>
        <rect x="7" y="14" width="3" height="10" fill="#E7D28C"/>
        <rect x="14.5" y="14" width="3" height="10" fill="#E7D28C"/>
        <rect x="22" y="14" width="3" height="10" fill="#E7D28C"/>
        <rect x="5" y="25" width="22" height="2.5" fill="#E7D28C"/>
      </svg>
      Vulnerable Bank
    </a>
    <div class="vb-topbar-actions">
      <a href="/dashboard" class="vb-btn vb-btn-ghost">Về Tổng quan</a>
    </div>
  </div>

  <div class="vb-vault-shell">
    <div class="vb-card">
      <div class="vb-vault-dial">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="10" width="16" height="10" rx="2" stroke="#12315C" stroke-width="2"/>
          <path d="M7 10V7a5 5 0 0110 0v3" stroke="#12315C" stroke-width="2"/>
          <circle cx="12" cy="15" r="1.6" fill="#12315C"/>
        </svg>
      </div>

      <h4 style="margin:0 0 6px;">Tài khoản Dự Trữ VIP</h4>
      <p style="color:var(--text-600); font-size:0.9rem; margin-bottom:4px;">
        Dành cho khách hàng có tổng tài sản đạt hạn mức Kho Bạc Trung Ương.
        Mở tài khoản để nhận mã xác thực truy cập đặc quyền.
      </p>
      <div class="vb-badge-req">Yêu cầu tối thiểu: <%= price.toLocaleString('vi-VN') %> ₫</div>

      <div style="margin: 20px 0; padding: 14px; background:#F8F9FC; border-radius:10px;">
        <div style="font-size:0.78rem; color:var(--text-400); text-transform:uppercase; letter-spacing:0.05em;">Số dư hiện tại</div>
        <div class="mono" style="font-size:1.3rem; font-weight:600; color:var(--navy-900);"><%= user.balance.toLocaleString('vi-VN') %> ₫</div>
      </div>

      <% if (error) { %>
        <div class="vb-alert vb-alert-danger"><%= error %></div>
      <% } %>

      <% if (flag) { %>
        <div class="vb-alert vb-alert-success" style="margin-bottom:8px;">Tài khoản Dự Trữ VIP đã được kích hoạt</div>
        <div style="font-size:0.78rem; color:var(--text-400); text-transform:uppercase; letter-spacing:0.05em; text-align:left;">Mã xác thực Kho Bạc Trung Ương</div>
        <div class="vb-vault-code"><%= flag %></div>
      <% } else { %>
        <form method="POST" action="/buy-flag">
          <button type="submit" class="vb-btn vb-btn-gold vb-btn-block">Mở tài khoản Dự Trữ VIP</button>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>
