<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Mua Flag - Vulnerable Bank</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark px-3">
    <span class="navbar-brand">🏦 Vulnerable Bank</span>
    <a href="/dashboard" class="btn btn-sm btn-outline-light">Quay lại Dashboard</a>
  </nav>

  <div class="container d-flex flex-column align-items-center justify-content-center" style="min-height:70vh;">
    <div class="card shadow p-4 text-center" style="width: 420px;">
      <h3>🚩 Cửa hàng Flag</h3>
      <p>Giá: <strong><%= price.toLocaleString('vi-VN') %> VND</strong></p>
      <p>Số dư hiện tại: <strong><%= user.balance.toLocaleString('vi-VN') %> VND</strong></p>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (flag) { %>
        <div class="alert alert-success"><%= flag %></div>
      <% } else { %>
        <form method="POST" action="/buy-flag">
          <button type="submit" class="btn btn-warning w-100">Mua Flag</button>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>
