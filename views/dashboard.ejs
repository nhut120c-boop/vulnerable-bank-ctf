<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Vulnerable Bank</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark px-3">
    <span class="navbar-brand">🏦 Vulnerable Bank</span>
    <div>
      <span class="text-white me-3">Xin chào, <%= user.username %></span>
      <a href="/buy-flag" class="btn btn-sm btn-warning me-2">Mua Flag</a>
      <a href="/logout" class="btn btn-sm btn-outline-light">Đăng xuất</a>
    </div>
  </nav>

  <div class="container py-4">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <h5 class="card-title">Số dư</h5>
            <p class="fs-3 fw-bold text-success"><%= user.balance.toLocaleString('vi-VN') %> VND</p>
          </div>
        </div>

        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Chuyển tiền</h5>
            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <form method="POST" action="/transfer">
              <div class="mb-2">
                <label class="form-label">Người nhận (username)</label>
                <input type="text" name="to" class="form-control" required>
              </div>
              <div class="mb-2">
                <label class="form-label">Số tiền (VND)</label>
                <input type="number" name="amount" class="form-control" min="1" required>
              </div>
              <div class="mb-2">
                <label class="form-label">Nội dung chuyển khoản</label>
                <input type="text" name="content" class="form-control" placeholder="VD: trả tiền cafe">
              </div>
              <small class="text-muted">Phí giao dịch: 10%</small>
              <button type="submit" class="btn btn-primary w-100 mt-2">Chuyển tiền</button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title">Lịch sử giao dịch toàn hệ thống</h5>
            <table class="table table-striped align-middle">
              <thead>
                <tr>
                  <th>Từ</th>
                  <th>Đến</th>
                  <th>Số tiền</th>
                  <th>Phí</th>
                  <th>Nội dung</th>
                  <th>Thời gian</th>
                </tr>
              </thead>
              <tbody>
                <% transactions.forEach(tx => { %>
                  <tr>
                    <td><%= tx.from %></td>
                    <td><%= tx.to %></td>
                    <td><%= tx.amount.toLocaleString('vi-VN') %></td>
                    <td><%= tx.fee.toLocaleString('vi-VN') %></td>
                    <!-- cố tình không encode: nội dung chuyển khoản render thẳng ra html -->
                    <td><%- tx.content %></td>
                    <td><%= new Date(tx.time).toLocaleString('vi-VN') %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
