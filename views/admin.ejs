<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Bảng điều khiển Vận hành | Vulnerable Bank</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="vb-topbar" style="background: linear-gradient(135deg, #7A1F1F, #4A1414);">
    <a href="/admin" class="vb-logo">
      <svg class="mark" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L4 5v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V5l-8-3z" stroke="#E7D28C" stroke-width="1.6"/>
      </svg>
      Vulnerable Bank — Vận hành
    </a>
    <div class="vb-topbar-actions">
      <a href="/dashboard" class="vb-btn vb-btn-ghost">Dashboard</a>
    </div>
  </div>

  <div class="vb-vault-shell">
    <div class="vb-card" style="text-align:left;">
      <h5 style="margin:0 0 4px;">Điều chỉnh số dư đặc quyền</h5>
      <p style="color:var(--text-600); font-size:0.85rem; margin-bottom:18px;">
        Chức năng nội bộ dành cho nhân viên vận hành đã xác thực.
      </p>
      <div id="msg"></div>
      <form id="mintForm">
        <label class="vb-label">Tài khoản nhận</label>
        <input type="text" id="targetUsername" class="vb-input" style="margin-bottom:12px;" required>

        <label class="vb-label">Số tiền</label>
        <input type="number" id="amount" class="vb-input" style="margin-bottom:12px;" min="1" required>

        <label class="vb-label">Mã PIN xác thực (4 số)</label>
        <input type="text" id="pin" class="vb-input" style="margin-bottom:16px;" maxlength="4" required>

        <button type="submit" class="vb-btn vb-btn-primary vb-btn-block">Thực thi</button>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('mintForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const targetUsername = document.getElementById('targetUsername').value;
      const amount = document.getElementById('amount').value;
      const pin = document.getElementById('pin').value;

      const res = await fetch('/api/admin/mint-money', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ targetUsername, amount, pin }),
      });
      const data = await res.json();
      const msgDiv = document.getElementById('msg');
      if (data.status === 'success') {
        msgDiv.innerHTML = '<div class="vb-alert vb-alert-success">Thành công. Số dư mới: ' + data.newBalance.toLocaleString('vi-VN') + ' ₫</div>';
      } else {
        msgDiv.innerHTML = '<div class="vb-alert vb-alert-danger">' + data.message + '</div>';
      }
    });
  </script>
</body>
</html>
