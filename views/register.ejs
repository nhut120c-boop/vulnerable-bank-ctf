<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Đăng ký - Vulnerable Bank</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container d-flex flex-column align-items-center justify-content-center" style="min-height:100vh;">
    <div class="card shadow p-4" style="width: 380px;">
      <h3 class="text-center mb-3">Đăng ký tài khoản</h3>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form method="POST" action="/register">
        <div class="mb-3">
          <label class="form-label">Username</label>
          <input type="text" name="username" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary w-100">Đăng ký (nhận 10,000 VND)</button>
      </form>
      <a href="/login" class="d-block text-center mt-3">Đã có tài khoản? Đăng nhập</a>
    </div>
  </div>
</body>
</html>
