<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Mở tài khoản | Vulnerable Bank</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="vb-auth-shell">
    <div class="vb-card vb-auth-card">
      <div class="vb-logo">
        <svg class="mark" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="8" fill="#12315C"/>
          <path d="M16 6L27 11V13H5V11L16 6Z" fill="#E7D28C"/>
          <rect x="7" y="14" width="3" height="10" fill="#E7D28C"/>
          <rect x="14.5" y="14" width="3" height="10" fill="#E7D28C"/>
          <rect x="22" y="14" width="3" height="10" fill="#E7D28C"/>
          <rect x="5" y="25" width="22" height="2.5" fill="#E7D28C"/>
        </svg>
        Vulnerable Bank
      </div>
      <h5 style="text-align:center; margin: 0 0 4px;">Mở tài khoản mới</h5>
      <p style="text-align:center; color:var(--text-600); font-size:0.85rem; margin-bottom:20px;">
        Nhận ngay 10.000 VND vào số dư khởi điểm
      </p>

      <% if (error) { %>
        <div class="vb-alert vb-alert-danger"><%= error %></div>
      <% } %>

      <form method="POST" action="/register">
        <label class="vb-label">Tên đăng nhập</label>
        <input type="text" name="username" class="vb-input" style="margin-bottom:14px;" required>

        <label class="vb-label">Mật khẩu</label>
        <input type="password" name="password" class="vb-input" style="margin-bottom:18px;" required>

        <button type="submit" class="vb-btn vb-btn-primary vb-btn-block">Mở tài khoản</button>
      </form>
      <a href="/login" style="display:block; text-align:center; margin-top:16px; font-size:0.85rem; color:var(--navy-600);">Đã có tài khoản? Đăng nhập</a>
    </div>
  </div>
</body>
</html>
